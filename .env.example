EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_RECIPIENTS=recipient@company.com
TEAMS_WEBHOOK_URL=https://your-teams-webhook-url-here

# Google Gemini API (免費方案，從 https://aistudio.google.com 取得)
GEMINI_API_KEY=your_gemini_api_key_here

# iOS RSS 中繼 Proxy（GCP 環境用，繞過 Apple IP 封鎖）
# 設定為 n8n webhook URL，本地開發可留空
IOS_RSS_RELAY_URL=https://your-n8n-domain/webhook/ios-rss
IOS_RSS_RELAY_KEY=your_relay_api_key_here

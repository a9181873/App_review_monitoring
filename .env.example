# ────────────── 必要 ──────────────
# OpenRouter API Key（免費，用於 AI 語意分析）
# 從 https://openrouter.ai/keys 取得
OPENROUTER_API_KEY=

# ────────────── 選填 ──────────────
# Google Gemini API Key（備援 AI，從 https://aistudio.google.com 取得，免費方案）
GEMINI_API_KEY=

# App Store Connect API（iOS 即時評論，需 Apple Developer 帳號，USD $99/年）
# 不設定則自動降級到 iTunes RSS（有 24-72 小時延遲）
# 設定步驟請參考 ASC_SETUP_GUIDE.md
ASC_KEY_ID=
ASC_ISSUER_ID=
ASC_PRIVATE_KEY=
ASC_PRIVATE_KEY_PATH=

# Email 通知（Gmail SMTP）
EMAIL_SENDER=
EMAIL_PASSWORD=

# Microsoft Teams 通知
TEAMS_WEBHOOK_URL=

# ────────── 以下可保持預設 ──────────
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_RECIPIENTS=
EMAIL_ENABLED=false
TEAMS_ENABLED=false
